# ---------- Supabase ----------
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Database (Drizzle) ----------
# Supabase → Project Settings → Database → Connection string (URI, pooler)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ---------- Stripe ----------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Created by `stripe listen` or the webhook config in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe price IDs for your plans (create products in Stripe dashboard)
NEXT_PUBLIC_STRIPE_PRICE_ID_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID_YEARLY=price_xxx

# ---------- App ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
